###5' preference and length distribution 
samtools view -F 4 output.bam | awk '{len=length($10); count[len]++; base[substr($10,1,1), len]++} END {for (i in count) {print count[i], i, base["A", i]+0, base["T", i]+0, base["G", i]+0, base["C", i]+0}}' | sort -k2,2n > output_read_length_freqs_and_first_base.txt
# ....repeat for each of the files

### Genomic features

sort -k1,1 -k4,4n -k5,5n Araport11_GFF3_genes_transposons.current.gff > sorted_Araport11_GFF3_genes_transposons.current.gff 

awk -F'\t' 'NF == 9' sorted_Araport11_GFF3_genes_transposons.current.gff > cleaned_sorted_Araport11_GFF3_genes_transposons.current.gff

bedtools complement -i cleaned_sorted_Araport11_GFF3_genes_transposons.current.gff -g chrNameLength.txt > Araport11_GFF3_intergenic.gff

awk '{print $0 "\tintergenic_region"}' Araport11_GFF3_intergenic.gff > Araport11_GFF3_intergenic_regions.gff

awk 'BEGIN{OFS="\t"} {print $1, ".", $4, $2, $3, ".", ".", ".", "-"}' Araport11_GFF3_intergenic_regions.gff > Araport11_GFF3_intergenic_regions_formatted.gff

cat cleaned_sorted_Araport11_GFF3_genes_transposons.current.gff Araport11_GFF3_intergenic_regions_formatted.gff > cleaned_sorted_Araport11_GFF3_genes_transposons.current.gff

bedtools coverage -a cleaned_sorted_Araport11_GFF3_genes_transposons.current.gff -b output.bam -f 0.5 > output_enriched_genomic_features.txt

